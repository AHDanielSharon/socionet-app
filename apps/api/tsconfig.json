{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "dist",
    "rootDir": "src",

    "baseUrl": "./src",
    "paths": {
  "@config/*": ["config/*"],
  "@lib/*": ["lib/*"],
  "@routes/*": ["routes/*"],
  "@utils/*": ["utils/*"],
  "@middleware/*": ["middleware/*"],
  "@services/*": ["services/*"],
  "@validators/*": ["validators/*"],
  "@jobs/*": ["jobs/*"]
}

    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": false,
    "skipLibCheck": true
  },
  "include": ["src"]
}
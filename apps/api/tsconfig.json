{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "outDir": "dist",
    "rootDir": "src",

    "baseUrl": "./src",
    "paths": {
      "@config/*": ["config/*"],
      "@lib/*": ["lib/*"],
      "@routes/*": ["routes/*"],
      "@utils/*": ["utils/*"],
      "@middleware/*": ["middleware/*"],
      "@services/*": ["services/*"],
      "@validators/*": ["validators/*"],
      "@jobs/*": ["jobs/*"]
    },

    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false
  },
  "include": ["src"]
}